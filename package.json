{
  "name": "bible-chrome-extension",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Midvash Chrome extension — detects Bible references on any page and links them to midvash.com with a hover preview tooltip.",
  "license": "MIT",
  "homepage": "https://midvash.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/midvash/bible-chrome-extension.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:parser": "tsx scripts/test-parser.ts",
    "zip": "cd dist && zip -r ../midvash-extension.zip ."
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.0.0-beta.28",
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0",
    "vite": "^8.0.14"
  }
}
